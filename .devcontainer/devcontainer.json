{
  "name": "Python Data Environment",
  
  // This pulls the official Microsoft image containing Python 3.11
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",

  // This tells the Codespace to install your libraries after the machine boots up
  "postCreateCommand": "pip install -r requirements.txt",

  // This automatically installs helpful Python extensions in VS Code for anyone using this space
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter"
      ]
    }
  }
}
